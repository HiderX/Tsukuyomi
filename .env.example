# 复制为 .env 并填写（.env 已加入 .gitignore，不会提交）
# cp api/.env.example api/.env

# OpenAI 兼容对话（用于 /v1/chat/completions 代理）
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=sk-xxx
# 默认模型（请求未带 model 时使用）
OPENAI_CHAT_MODEL=gpt-4o-mini

# 可选：月读空间/网站运行状态页（与 iframe 内 Uptime Kuma 一致，用于回答「运行状态」类问题）
# 不填则默认 https://status.qkv.io/status/default
# STATUS_PAGE_URL=https://status.qkv.io/status/default

# 调试：设为 1 或 true 时，后端与前端都会打日志（动作解析、强制 cry、runAction 等）
# DEBUG=0

# 服务
PORT=5000
HOST=0.0.0.0
