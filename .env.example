# 复制为 .env 并填写（.env 已加入 .gitignore，不会提交）
# cp api/.env.example api/.env

# OpenAI 兼容对话（用于 /v1/chat/completions 代理）
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=sk-xxx
# 默认模型（请求未带 model 时使用）
OPENAI_CHAT_MODEL=gpt-4o-mini

# 可选：月读空间/网站运行状态页（Uptime Kuma），用于回答「运行状态」类问题
# 不填则默认同机本端口 http://127.0.0.1:3001/status/default；状态页在别机或不同端口时在此指定
# STATUS_PAGE_URL=http://127.0.0.1:3001/status/default

# 调试：设为 1 或 true 时，后端与前端都会打日志（动作解析、强制 cry、runAction 等）
# DEBUG=0

# 服务
PORT=5000
HOST=0.0.0.0
